<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@drawable/gradient_top_shadow">

        <TextView
            android:id="@+id/txtFaceTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Face Recognition"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunito_bold" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/circle_white_20">
            <Button
                android:id="@+id/btnClose"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:padding="0dp" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Activity Status Pill -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="76dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#CC000000"
        app:strokeWidth="1dp"
        app:strokeColor="#40FFFFFF">
        <TextView
            android:id="@+id/txtActivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyzing..."
            android:textColor="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textSize="13sp"
            android:fontFamily="@font/nunito_bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/gradient_bottom_shadow">

        <!-- Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/txtResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#1a3a40"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/nunito_bold" />
                <TextView
                    android:id="@+id/txtRelation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#546E7A"
                    android:textSize="16sp"
                    android:fontFamily="@font/nunito_regular" />
                <TextView
                    android:id="@+id/txtConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/nunito_bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point camera at person"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="10dp"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_bold" />

        <!-- Scan Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:text="SCAN FACE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/nunito_bold"
                android:backgroundTint="#2E7D8C"
                app:cornerRadius="34dp"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconGravity="textStart"
                app:iconSize="22dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerInParent="true"
                android:elevation="10dp"
                android:visibility="gone"
                android:indeterminateTint="#FFFFFF" />
        </RelativeLayout>

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <TextView android:id="@+id/txtCameraMode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <Button android:id="@+id/btnCameraSwitch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>
</FrameLayout>