<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Logo circle -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_teal_light"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/logo1"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caregiver Login"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginBottom="6dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to manage patient care"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginBottom="28dp" />

        <!-- Email Label -->
        <TextView
            android:id="@+id/txtEmailLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginBottom="6dp" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="16dp" />

        <!-- Password Label -->
        <TextView
            android:id="@+id/txtPasswordLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginBottom="6dp" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:textSize="16sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="8dp" />

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/txtForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/nunito_bold"
            android:gravity="end"
            android:layout_marginBottom="24dp" />

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Login"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/nunito_bold"
            android:backgroundTint="#388E3C"
            app:cornerRadius="16dp"
            android:layout_marginBottom="14dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Register Link -->
        <TextView
            android:id="@+id/txtRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New caregiver? Register here"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="← Back"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/nunito_bold"
            android:backgroundTint="@color/text_secondary"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>
</ScrollView>