<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtExerciseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Exercise"
            android:fontFamily="@font/nunito_bold"
            android:textSize="32sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose an activity to begin"
            android:fontFamily="@font/nunito_regular"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="28dp"/>

        <!-- Card: Reality Orientation -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardReality"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="📅"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="#E8F4F6"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvRealityTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reality Orientation"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvRealitySubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date, time &amp; place awareness"
                        android:fontFamily="@font/nunito_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Memory Recall -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemory"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="🧠"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="#EDE7F6"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvMemoryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Memory Recall"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvMemorySubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Look, remember &amp; answer"
                        android:fontFamily="@font/nunito_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Name & Face -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNameFace"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="👤"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="#FFF3E0"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvNameFaceTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name &amp; Face"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvNameFaceSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recognise family &amp; friends"
                        android:fontFamily="@font/nunito_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Breathing -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBreathing"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="🌬️"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvBreathingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Breathing Relaxation"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvBreathingSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm your mind &amp; body"
                        android:fontFamily="@font/nunito_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Back Button -->
        <Button
            android:id="@+id/btnBack"
            style="@style/RoundedButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="← Back to Home"
            android:fontFamily="@font/nunito_bold"
            android:textSize="18sp"
            android:backgroundTint="@color/text_secondary"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>