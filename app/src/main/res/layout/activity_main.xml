<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6F1">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:background="#2E7D8C"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">



                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="خوش آمدید"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/nunito_bold"
                    android:gravity="center" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Grid Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- Family -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFamily"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#EFF6FF"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/icon_box_blue">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_family"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                        <TextView
                            android:id="@+id/txtFamilyLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="خاندان دیکھیں"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1e3a5f"
                            android:fontFamily="@font/nunito_bold"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Reminders -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReminders"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFBEB"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/icon_box_amber">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bell"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                        <TextView
                            android:id="@+id/txtRemindersLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="یاد دہانی"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#451a03"
                            android:fontFamily="@font/nunito_bold"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Grid Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Exercise -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExercise"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FAF5FF"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/icon_box_purple">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_brain"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                        <TextView
                            android:id="@+id/txtExerciseLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ورزش"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2e1065"
                            android:fontFamily="@font/nunito_bold"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Face / Who is this -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFace"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#F0FDF4"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/icon_box_emerald">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_eye"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                        <TextView
                            android:id="@+id/txtFaceLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="یہ کون ہے؟"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#052e16"
                            android:fontFamily="@font/nunito_bold"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Repeat Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRepeat"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="🔊  دوبارہ سنیں"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/nunito_bold"
                app:cornerRadius="16dp"
                android:backgroundTint="#2E7D8C" />

            <!-- Emergency Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEmergency"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#C62828"
                app:cardElevation="6dp"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚨  EMERGENCY"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_bold" />
                    <TextView
                        android:id="@+id/txtEmergencySub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الرٹ کے لیے دبائے رکھیں"
                        android:textColor="#FFCDD2"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>